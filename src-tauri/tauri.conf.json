{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rhythm Desktop",
  "version": "0.1.0",
  "identifier": "com.rhythm.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rhythm Desktop",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ]
  }
}
