{
  "name": "my-plugin",
  "version": "0.1.0",
  "description": "A Rhythm JS plugin template.",
  "main": "dist/main.js",
  "dev": {
    "main": "src/main.tsx"
  },
  "enabledByDefault": false,
  "permissions": [],
  "requires": {
    "plugins": {},
    "commands": [],
    "tools": []
  },
  "contributes": {
    "commands": [
      {
        "id": "my-plugin.hello",
        "description": "Return a simple greeting.",
        "parameters": {
          "type": "object",
          "properties": {}
        },
        "implementation": "ui",
        "entry": "dist/main.js",
        "handler": "my-plugin.hello"
      }
    ],
    "views": [
      {
        "id": "my-plugin.panel",
        "title": "My Plugin",
        "location": "leftPanel"
      },
      {
        "id": "my-plugin.preview",
        "title": "My Plugin Preview",
        "location": "workbench"
      }
    ]
  }
}
