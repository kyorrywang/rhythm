{
  "name": "folder",
  "version": "0.1.0",
  "description": "Workspace folder tree and file actions.",
  "main": "dist/main.js",
  "dev": {
    "main": "src/main.tsx"
  },
  "enabledByDefault": true,
  "permissions": [
    "workspace.files.read",
    "workspace.files.write",
    "system.openPath"
  ],
  "requires": {
    "commands": ["tool.list_dir", "tool.read_file", "tool.write_file", "tool.delete_file"],
    "tools": []
  },
  "contributes": {
    "commands": [
      {
        "id": "folder.createDir",
        "description": "Create a folder in the current workspace.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string" }
          },
          "required": ["path"]
        },
        "readOnly": false,
        "implementation": "node",
        "entry": "src/commands/main.js",
        "handler": "createDir",
        "permissions": ["workspace.files.write"]
      },
      {
        "id": "folder.rename",
        "description": "Rename or move a file or folder in the current workspace.",
        "parameters": {
          "type": "object",
          "properties": {
            "from": { "type": "string" },
            "to": { "type": "string" }
          },
          "required": ["from", "to"]
        },
        "readOnly": false,
        "implementation": "node",
        "entry": "src/commands/main.js",
        "handler": "rename",
        "permissions": ["workspace.files.write"]
      },
      {
        "id": "folder.reveal",
        "description": "Reveal a file or folder in the operating system file manager.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string" }
          },
          "required": ["path"]
        },
        "readOnly": true,
        "implementation": "node",
        "entry": "src/commands/main.js",
        "handler": "reveal",
        "permissions": ["system.openPath"]
      },
      {
        "id": "folder.delete",
        "description": "Delete a file or folder in the current workspace.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "recursive": { "type": "boolean" }
          },
          "required": ["path"]
        },
        "readOnly": false,
        "implementation": "node",
        "entry": "src/commands/main.js",
        "handler": "deletePath",
        "permissions": ["workspace.files.write"]
      },
      {
        "id": "folder.openFile",
        "description": "Open a workspace file in the Folder preview view.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "line": { "type": "number" },
            "column": { "type": "number" }
          },
          "required": ["path"]
        },
        "readOnly": true,
        "implementation": "ui",
        "entry": "dist/main.js",
        "handler": "folder.openFile"
      }
    ],
    "views": [
      {
        "id": "folder.tree",
        "title": "Files",
        "location": "leftPanel"
      },
      {
        "id": "folder.file.preview",
        "title": "File Preview",
        "location": "workbench"
      }
    ]
  }
}
