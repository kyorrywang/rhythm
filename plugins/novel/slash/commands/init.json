{
  "name": "novel:init",
  "title": "初始化小说项目",
  "description": "初始化小说项目配置，并通过问答流生成 .novel/project.yaml。",
  "kind": "workflow",
  "provider": {
    "type": "plugin",
    "id": "novel"
  },
  "entry": {
    "id": "init"
  },
  "handler": {
    "id": "init"
  },
  "skillFiles": ["init.md"],
  "outputHints": [
    {
      "path": ".novel/project.yaml",
      "description": "初始化完成后，在确认关键信息后创建或更新小说项目配置。"
    }
  ],
  "defaultSkill": "default",
  "contextPolicy": "default"
}
