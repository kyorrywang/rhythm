{
  "name": "novel:discuss-arc",
  "title": "探讨正文剧情",
  "description": "围绕未来 3-5 章的小剧情做多轮正文探讨。",
  "kind": "workflow",
  "provider": {
    "type": "plugin",
    "id": "novel"
  },
  "entry": {
    "id": "discuss-arc"
  },
  "handler": {
    "id": "discuss-arc"
  },
  "skillFiles": ["discuss-arc.md"],
  "outputHints": [
    {
      "path": ".novel/discovery/arc-discussion.md",
      "description": "如发生有效剧情探讨，可沉淀本次小剧情讨论记录。"
    },
    {
      "path": ".novel/discovery/arc-brief.md",
      "description": "如讨论足够清晰，可整理为后续创作复用的剧情 brief。"
    }
  ],
  "defaultSkill": "default",
  "contextPolicy": "default"
}
