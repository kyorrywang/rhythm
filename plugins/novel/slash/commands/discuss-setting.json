{
  "name": "novel:discuss-setting",
  "title": "探讨设定",
  "description": "围绕题材、世界观、角色与风格做多轮设定探讨。",
  "kind": "workflow",
  "provider": {
    "type": "plugin",
    "id": "novel"
  },
  "entry": {
    "id": "discuss-setting"
  },
  "handler": {
    "id": "discuss-setting"
  },
  "skillFiles": ["discuss-setting.md"],
  "outputHints": [
    {
      "path": ".novel/discovery/setting-discussion.md",
      "description": "如发生有效设定探讨，可沉淀本次讨论记录。"
    },
    {
      "path": ".novel/discovery/setting-brief.md",
      "description": "如讨论足够清晰，可整理为后续创作复用的设定 brief。"
    }
  ],
  "defaultSkill": "default",
  "contextPolicy": "default"
}
