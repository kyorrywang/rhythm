{
  "name": "workflow",
  "version": "0.1.0",
  "description": "Workflow list, editor and lightweight runner.",
  "main": "dist/main.js",
  "dev": {
    "main": "src/main.tsx"
  },
  "enabledByDefault": true,
  "permissions": [
    "terminal.run",
    "plugin.command.invoke"
  ],
  "requires": {
    "commands": [
      "core.llm.complete",
      "tool.shell"
    ],
    "tools": []
  },
  "contributes": {
    "commands": [
      {
        "id": "workflow.create",
        "description": "Create a workflow definition.",
        "parameters": {
          "type": "object",
          "properties": {
            "name": { "type": "string" }
          }
        },
        "implementation": "ui",
        "entry": "dist/main.js",
        "handler": "workflow.create"
      },
      {
        "id": "workflow.run",
        "description": "Run a workflow definition.",
        "parameters": {
          "type": "object",
          "properties": {
            "workflowId": { "type": "string" }
          },
          "required": ["workflowId"]
        },
        "implementation": "ui",
        "entry": "dist/main.js",
        "handler": "workflow.run"
      },
      {
        "id": "workflow.cancel",
        "description": "Cancel a workflow run.",
        "parameters": {
          "type": "object",
          "properties": {
            "runId": { "type": "string" }
          },
          "required": ["runId"]
        },
        "implementation": "ui",
        "entry": "dist/main.js",
        "handler": "workflow.cancel"
      },
      {
        "id": "workflow.registerNodeType",
        "description": "Register a Workflow node type from another plugin.",
        "parameters": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "title": { "type": "string" }
          },
          "required": ["id", "title"]
        },
        "implementation": "ui",
        "entry": "dist/main.js",
        "handler": "workflow.registerNodeType"
      },
      {
        "id": "workflow.getStatus",
        "description": "Get workflow run status.",
        "parameters": {
          "type": "object",
          "properties": {
            "runId": { "type": "string" }
          },
          "required": ["runId"]
        },
        "implementation": "ui",
        "entry": "dist/main.js",
        "handler": "workflow.getStatus"
      }
    ],
    "views": [
      {
        "id": "workflow.panel",
        "title": "Workflows",
        "location": "leftPanel"
      },
      {
        "id": "workflow.editor",
        "title": "Workflow Editor",
        "location": "workbench"
      },
      {
        "id": "workflow.run",
        "title": "Workflow Run",
        "location": "workbench"
      },
      {
        "id": "workflow.nodeInspector",
        "title": "Node Inspector",
        "location": "workbench"
      }
    ],
    "settings": [
      {
        "id": "workflow.settings",
        "title": "Workflow"
      }
    ],
    "tools": [
      {
        "id": "workflow.create",
        "description": "Create a workflow definition.",
        "parameters": {
          "type": "object",
          "properties": {
            "name": { "type": "string" }
          }
        },
        "readOnly": false,
        "runtime": "node",
        "entry": "src/tools/main.js",
        "handler": "create"
      },
      {
        "id": "workflow.run",
        "description": "Run a workflow definition and return the run trace.",
        "parameters": {
          "type": "object",
          "properties": {
            "workflowId": { "type": "string" }
          },
          "required": ["workflowId"]
        },
        "readOnly": false,
        "runtime": "node",
        "entry": "src/tools/main.js",
        "handler": "run"
      },
      {
        "id": "workflow.getStatus",
        "description": "Get a workflow run status.",
        "parameters": {
          "type": "object",
          "properties": {
            "runId": { "type": "string" }
          },
          "required": ["runId"]
        },
        "readOnly": true,
        "runtime": "node",
        "entry": "src/tools/main.js",
        "handler": "getStatus"
      }
    ]
  }
}
